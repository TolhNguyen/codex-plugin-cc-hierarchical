{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent",
  "description": "Definition of a persistent or temporary agent identity in the runtime roster.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "type",
    "status",
    "ownership",
    "responsibilities",
    "skills",
    "memory",
    "permissions",
    "runtime",
    "limits"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "name": {
      "type": "string"
    },
    "type": {
      "type": "string",
      "enum": [
        "persistent",
        "temporary"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "proposed",
        "active",
        "retired"
      ]
    },
    "ownership": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "primary",
        "secondary",
        "excluded"
      ],
      "properties": {
        "primary": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "secondary": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "excluded": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "responsibilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^(core|technical|project|domain)/[a-z0-9-]+@\\d+\\.\\d+\\.\\d+$"
      }
    },
    "memory": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "namespaces"
      ],
      "properties": {
        "namespaces": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "permissions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "read",
        "write"
      ],
      "properties": {
        "read": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "write": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "provider",
        "model"
      ],
      "properties": {
        "provider": {
          "type": "string"
        },
        "model": {
          "type": "string"
        }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "maxAttemptsPerTask",
        "maxExecutionMinutes",
        "maxToolCalls"
      ],
      "properties": {
        "maxAttemptsPerTask": {
          "type": "integer",
          "minimum": 1
        },
        "maxExecutionMinutes": {
          "type": "integer",
          "minimum": 1
        },
        "maxToolCalls": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "approvals": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "role",
          "decision",
          "at"
        ],
        "properties": {
          "role": {
            "type": "string"
          },
          "decision": {
            "type": "string"
          },
          "at": {
            "type": "string"
          }
        }
      }
    }
  }
}
