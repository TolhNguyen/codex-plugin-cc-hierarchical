{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ProjectProfile",
  "description": "Repository analysis output describing a project's languages, structure and capabilities.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "generatedAt",
    "languages",
    "commands",
    "structure",
    "capabilities"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "generatedAt": {
      "type": "string"
    },
    "languages": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "frameworks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "commands": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "test": {},
        "build": {},
        "lint": {}
      }
    },
    "structure": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dirs",
        "entryPoints"
      ],
      "properties": {
        "dirs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "entryPoints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "testLayout": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dir": {
          "type": "string"
        },
        "pattern": {
          "type": "string"
        },
        "runner": {
          "type": "string"
        }
      }
    },
    "ci": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": {
          "type": "string"
        },
        "workflows": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "docs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "technical",
        "domains",
        "crossCutting"
      ],
      "properties": {
        "technical": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "domains": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "crossCutting": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
