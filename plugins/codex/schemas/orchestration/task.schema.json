{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Task",
  "description": "A unit of work assigned to an agent within a campaign.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "taskId",
    "campaignId",
    "title",
    "goal",
    "affectedPaths",
    "requiredSkills",
    "owner",
    "verificationCommands",
    "acceptanceCriteria",
    "maxAttempts",
    "status"
  ],
  "properties": {
    "taskId": {
      "type": "string"
    },
    "campaignId": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "goal": {
      "type": "string"
    },
    "affectedPaths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "requiredSkills": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "owner": {
      "type": "string"
    },
    "verificationCommands": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptanceCriteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "maxAttempts": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "routed",
        "in_progress",
        "needs_review",
        "approved",
        "failed",
        "escalated",
        "cancelled"
      ]
    },
    "support": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "contextFiles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "attempts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    }
  }
}
